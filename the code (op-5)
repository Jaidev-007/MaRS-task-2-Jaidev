#include <Wire.h>
#include <LiquidCrystal_I2C.h>
const int ir =2;
int count = 0;
LiquidCrystal_I2C lcd(0x27,16,2);

void setup() {
  // Wire.begin();
  lcd.init();
  lcd.backlight();//To Power ON the back light
  Serial.begin(9600);
  pinMode(ir,INPUT);
  lcd.begin(16,2);//Defining 16 columns and 2 rows of lcd display
  
  
  lcd.clear();//Clean the screen
  lcd.setCursor(0,0); //Defining positon to write from first column,first row .

  lcd.write("obj count : "); //You can write 16 Characters per line .

  Serial.print("obj count: ");
  lcd.setCursor(0,1);  //Defining positon to write from first column,second row .
  lcd.write(count);
  Serial.println(count);
}

void loop() 
{
  if(digitalRead(ir)!=HIGH){
    print();
    while(digitalRead(ir)==LOW){
    }
  }
}

void print(){
  count++;//increasing the count value if the object is there
  lcd.clear();//Cleaning the screen
  lcd.setCursor(0,0); //Defining positon to write from first column,first row .

  lcd.write("obj count : "); //You can write 16 Characters per line .

  Serial.print("obj count: ");
  lcd.setCursor(0,1);  //Defining positon to write from first column,second row .
  lcd.write(count);
  Serial.println(count);
}
